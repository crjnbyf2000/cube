CREATE TABLE stage.lk_inform
(
    `mpioip` String,
    `last_login_at` Nullable(Date)
)
ENGINE = MergeTree
ORDER BY mpioip
SETTINGS index_granularity = 8192;



TRUNCATE TABLE stage.lk_inform;
INSERT INTO stage.lk_inform
(
mpioip,
last_login_at
)
SELECT
mpi_oip AS mpioip,
max(last_login_at) AS last_login_at
FROM raw.person_info
WHERE mpi_oip != ''
GROUP BY mpi_oip;
