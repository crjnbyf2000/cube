drop table stage.disp_info
CREATE TABLE stage.disp_info
(
 id String,
 episod_id String,
    group_cd Int32,
    ds_cd String,
    mo_cd Int32,
    in_dt Date,
    out_dt Nullable(Date),
    mpioip String
)
ENGINE = MergeTree
ORDER BY (id, mpioip)
SETTINGS index_granularity = 8192;
INSERT INTO stage.disp_info
(
    id,
    episod_id,
    group_cd,
    ds_cd,
    mo_cd,
    in_dt,
    out_dt,
    mpioip
)
SELECT
    id,
    episod_id,
    group_cd,
    ds_cd,
    mo_cd,
    in_dt,
    out_dt,
    mpioip
FROM
(
    SELECT
        cmp_id AS id,
        id as episod_id,
        toInt32(splitByChar('/', diagnosis_group_reference)[2]) AS group_cd,
        arrayElement(splitByChar('/', diagnosis_reference), 2) AS ds_cd,
        toInt32(splitByChar('/', mo_reference)[2]) AS mo_cd,
        period_start AS in_dt,
        period_end AS out_dt,
        mpi_oip AS mpioip,
        row_number() OVER (
            PARTITION BY id
            ORDER BY created_at DESC
        ) AS rn
    FROM raw.event_dispensary_episode
)
WHERE rn = 1;

