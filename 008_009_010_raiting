-- 4. rating_base
drop table tmp.rating_base
CREATE TABLE tmp.rating_base
(
    plan_id         UUID,
    episod_id       String,
    profile_cd      Int32,
    plan_start_date Date,
    plan_end_date   Nullable(Date),
    disp_id         Int64,
    mpioip          String,
    group_cd        Int32,
    ds_cd           String,
    disp_in_dt      Date,
    disp_out_dt     Nullable(Date),
    disp_mo_cd      String,
    birth_dt        Date,
    death_dt        Nullable(Date),
    pol_cd          Int64,
    ok_region_cd    String,
    smo_region_cd   String,
    smo_cd          String,
    attach_mo_cd    String
)
ENGINE = MergeTree
ORDER BY (mpioip, disp_id, plan_id)
SETTINGS index_granularity = 8192;
