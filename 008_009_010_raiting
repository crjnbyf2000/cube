TRUNCATE TABLE cube.mo_rating;
INSERT INTO cube.mo_rating
(
    f_y,
    f_q,
    f_region_smo_cd,
    f_profile_cd,
    f_dn_group_cd,
    f_smo,
    f_mo,
    mo_cd,
    insured_cnt,
    sl_dn_cnt,
    all_tasks,
    task_done_cnt,
    task_done_prc,
    charge_item_cnt,
    insert_dttm,
    update_dttm
)
SELECT
    f_y,
    f_q,
    f_region_smo_cd,
    f_profile_cd,
    f_dn_group_cd,
    f_smo,
    f_mo,
    mo_cd,
    insured_cnt_sum AS insured_cnt,
    sl_dn_cnt_sum AS sl_dn_cnt,
    all_tasks_sum AS all_tasks,
    task_done_cnt_sum AS task_done_cnt,
    toDecimal64(
        if(
            all_tasks_sum > 0,
            round(task_done_cnt_sum * 100.0 / all_tasks_sum, 2),
            0
        ),
        2
    ) AS task_done_prc,
    charge_item_cnt_sum AS charge_item_cnt,
    now64(3, 'Europe/Moscow') AS insert_dttm,
    now64(3, 'Europe/Moscow') AS update_dttm
FROM
(
    SELECT
        f_y,
        f_q,
        f_region_smo_cd,
        f_profile_cd,
        f_dn_group_cd,
        f_smo,
        f_mo,
        mo_cd,
        sum(insured_cnt) AS insured_cnt_sum,
        sum(sl_dn_cnt) AS sl_dn_cnt_sum,
        sum(all_tasks) AS all_tasks_sum,
        sum(task_done_cnt) AS task_done_cnt_sum,
        sum(charge_item_cnt) AS charge_item_cnt_sum
    FROM precalc.rating_detail
    GROUP BY
        f_y,
        f_q,
        f_region_smo_cd,
        f_profile_cd,
        f_dn_group_cd,
        f_smo,
        f_mo,
        mo_cd
);
