TRUNCATE TABLE tmp.rating_base;
INSERT INTO tmp.rating_base
SELECT
    dp.plan_id,
    dp.episod_id,
    dp.profile_cd,
    dp.start_date AS plan_start_date,
    dp.end_date AS plan_end_date,
    di.disp_id,
    di.mpioip,
    di.group_cd,
    di.ds_cd,
    di.in_dt AS disp_in_dt,
    di.out_dt AS disp_out_dt,
    di.mo_cd AS disp_mo_cd,
    p.birth_dt,
    p.death_dt,
    p.pol_cd,
    p.ok_region_cd,
    p.smo_region_cd,
    p.smo_cd,
    p.attach_mo_cd
FROM stage.dispensary_plan dp
INNER JOIN stage.disp_info di
    ON di.episod_id = dp.episod_id
INNER JOIN stage.dispans_person p
    ON p.mpioip = di.mpioip
INSERT INTO tmp.rating_task_base
SELECT
    rb.mpioip,
    rb.disp_id,
    rb.plan_id,
    rb.profile_cd,
    rb.group_cd,
    rb.smo_region_cd AS region_smo_cd,
    rb.smo_cd,
    rb.disp_mo_cd AS mo_cd,
    t.task_id,
    t.task_status_cd,
    t.task_start,
    t.task_end,
    t.closed_dt,
    ifNull(tu.usl_id, '') AS usl_id
FROM tmp.rating_base rb
INNER JOIN stage.event_task t
    ON t.plan_id = rb.plan_id
LEFT JOIN stage.task_usl tu
    ON tu.task_id = t.task_id;
TRUNCATE TABLE precalc.rating_detail_part;
TRUNCATE TABLE precalc.rating_detail;
INSERT INTO precalc.rating_detail_part
SELECT
    cp.f_y,
    cp.f_q,
    if(bitTest(mask, 0), '0', rb.smo_region_cd) AS f_region_smo_cd,
    if(bitTest(mask, 1), '0', toString(rb.profile_cd)) AS f_profile_cd,
    if(bitTest(mask, 2), '0', toString(rb.group_cd)) AS f_dn_group_cd,
    if(bitTest(mask, 3), '0', rb.smo_cd) AS f_smo,
    if(bitTest(mask, 4), '0', rb.disp_mo_cd) AS f_mo,
    rb.smo_region_cd AS region_smo_cd,
    rb.smo_cd,
    rb.disp_mo_cd AS mo_cd,
    uniqExact(rb.mpioip) AS insured_cnt,
    uniqExact(rb.disp_id) AS sl_dn_cnt,
    toUInt64(0) AS all_tasks,
    toUInt64(0) AS task_done_cnt,
    toUInt64(0) AS charge_item_cnt
FROM tmp.rating_base rb
CROSS JOIN tmp.calc_periods cp
ARRAY JOIN range(32) AS mask
WHERE rb.disp_in_dt < cp.dt_to
  AND  (rb.disp_out_dt IS NULL  OR rb.disp_out_dt >= cp.dt_from )
GROUP BY
    cp.f_y,
    cp.f_q,
    f_region_smo_cd,
    f_profile_cd,
    f_dn_group_cd,
    f_smo,
    f_mo,
    region_smo_cd,
    rb.smo_cd,
    mo_cd;
INSERT INTO precalc.rating_detail_part
SELECT
    cp.f_y,
    cp.f_q,
    if(bitTest(mask, 0), '0', tb.region_smo_cd) AS f_region_smo_cd,
    if(bitTest(mask, 1), '0', toString(tb.profile_cd)) AS f_profile_cd,
    if(bitTest(mask, 2), '0', toString(tb.group_cd)) AS f_dn_group_cd,
    if(bitTest(mask, 3), '0', tb.smo_cd) AS f_smo,
    if(bitTest(mask, 4), '0', tb.mo_cd) AS f_mo,
    tb.region_smo_cd,
    tb.smo_cd,
    tb.mo_cd,
    toUInt64(0) AS insured_cnt,
    toUInt64(0) AS sl_dn_cnt,
    uniqExactIf(tb.task_id, tb.task_status_cd NOT IN (4, 5)) AS all_tasks,
    uniqExactIf(tb.task_id, tb.task_status_cd IN (1, 2)) AS task_done_cnt,
    uniqExactIf(tb.usl_id, tb.usl_id != '') AS charge_item_cnt
FROM tmp.rating_task_base tb
CROSS JOIN tmp.calc_periods cp
ARRAY JOIN range(32) AS mask
WHERE tb.task_start < cp.dt_to
  AND tb.task_end >= cp.dt_from
GROUP BY
    cp.f_y,
    cp.f_q,
    f_region_smo_cd,
    f_profile_cd,
    f_dn_group_cd,
    f_smo,
    f_mo,
    tb.region_smo_cd,
    tb.smo_cd,
    tb.mo_cd;
